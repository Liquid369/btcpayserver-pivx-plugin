@using BTCPayServer.Payments
@using BTCPayServer.Plugins.PIVX.Services
@inject PivxBalanceProvider PivxBalanceProvider
@inject BTCPayServer.Services.Rates.CurrencyNameTable CurrencyNameTable
@model BTCPayServer.Models.StoreViewModels.StoreDashboardViewModel
@{
    var store = Context.GetStoreData();
    var pmi = PaymentTypes.CHAIN.GetPaymentMethodId("PIVX");
    var enabled = store != null
        && store.GetPaymentMethodConfig(pmi) != null
        && !store.GetStoreBlob().GetExcludedPaymentMethods().Match(pmi);
}
@if (enabled)
{
    var balance = PivxBalanceProvider.GetBalance();
    var histogram = balance.Available ? PivxBalanceProvider.GetHistogram("week") : null;
    var defaultCurrency = store!.GetStoreBlob().DefaultCurrency;
    var divisibility = CurrencyNameTable.GetCurrencyData(defaultCurrency, true).Divisibility;
    var widgetId = $"PivxWalletBalance-{Model.StoreId}";

    <div id="@widgetId" class="widget store-wallet-balance">
        <div class="d-flex gap-3 align-items-center justify-content-between mb-2">
            <h6 class="d-flex align-items-center gap-2">
                <img src="~/pivx.svg" alt="PIVX" style="width:20px;height:20px;" />
                PIVX Balance
            </h6>
            @if (!string.Equals(defaultCurrency, "PIVX", StringComparison.OrdinalIgnoreCase))
            {
                <div class="btn-group btn-group-sm gap-0 currency-toggle" role="group">
                    <input type="radio" class="btn-check" name="PivxWalletBalance-currency" id="PivxWalletBalance-currency_PIVX" value="PIVX" autocomplete="off" checked>
                    <label class="btn btn-outline-secondary px-2 py-1" for="PivxWalletBalance-currency_PIVX">PIVX</label>
                    <input type="radio" class="btn-check" name="PivxWalletBalance-currency" id="PivxWalletBalance-currency_@defaultCurrency" value="@defaultCurrency" autocomplete="off">
                    <label class="btn btn-outline-secondary px-2 py-1" for="PivxWalletBalance-currency_@defaultCurrency">@defaultCurrency</label>
                </div>
            }
        </div>
        <header class="mb-3">
            @if (balance.Available)
            {
                <div class="balance d-flex align-items-baseline gap-1">
                    <h3 class="d-inline-block me-1" data-balance="@balance.Total" data-sensitive>@balance.Total.ToString("0.########")</h3>
                    <span class="text-secondary fw-semibold currency">PIVX</span>
                </div>
                @if (balance.Shield > 0)
                {
                    <div class="text-secondary small" data-sensitive>
                        @balance.Transparent.ToString("0.########") transparent / @balance.Shield.ToString("0.########") shield
                    </div>
                }
                @if (histogram != null)
                {
                    <div class="btn-group only-for-js mt-1" role="group" aria-label="Period">
                        <input type="radio" class="btn-check" name="PivxWalletBalancePeriod-@Model.StoreId" id="PivxWalletBalancePeriodWeek-@Model.StoreId" value="week" checked>
                        <label class="btn btn-link" for="PivxWalletBalancePeriodWeek-@Model.StoreId">1W</label>
                        <input type="radio" class="btn-check" name="PivxWalletBalancePeriod-@Model.StoreId" id="PivxWalletBalancePeriodMonth-@Model.StoreId" value="month">
                        <label class="btn btn-link" for="PivxWalletBalancePeriodMonth-@Model.StoreId">1M</label>
                        <input type="radio" class="btn-check" name="PivxWalletBalancePeriod-@Model.StoreId" id="PivxWalletBalancePeriodYear-@Model.StoreId" value="year">
                        <label class="btn btn-link" for="PivxWalletBalancePeriodYear-@Model.StoreId">1Y</label>
                    </div>
                }
            }
            else
            {
                <div class="text-secondary">PIVX daemon unavailable</div>
            }
        </header>
        @if (histogram != null)
        {
            <div class="ct-chart"></div>
        }
        <script>
            (function () {
                const storeId = @Safe.Json(Model.StoreId);
                const defaultCurrency = @Safe.Json(defaultCurrency);
                const divisibility = @Safe.Json(divisibility);
                let data = @Safe.Json(histogram == null ? null : new { labels = histogram.Labels, series = histogram.Series, balance = histogram.Balance });
                let rate = null;

                const id = `PivxWalletBalance-${storeId}`;
                const baseUrl = @Safe.Json(Url.Action("Histogram", "PivxStore", new { storeId = Model.StoreId, type = "week" }));
                const valueTransform = value => rate ? DashboardUtils.displayDefaultCurrency(value, rate, defaultCurrency, divisibility) : value;
                const labelCount = 6;

                // sit right below the default wallet balance widget when present
                function reposition() {
                    const self = document.getElementById(id);
                    const btc = document.getElementById(`StoreWalletBalance-${storeId}`);
                    if (self && btc) btc.insertAdjacentElement('afterend', self);
                }

                const dateFormatter = new Intl.DateTimeFormat('default', { month: 'short', day: 'numeric' });
                const chartOpts = {
                    fullWidth: true,
                    showArea: true,
                    axisY: { showLabel: false, offset: 0 },
                    plugins: [Chartist.plugins.tooltip2({
                        template: '<div class="chartist-tooltip-value">{{value}}</div><div class="chartist-tooltip-line"></div>',
                        offset: { x: 0, y: -16 },
                        valueTransformFunction(value, label) {
                            return valueTransform(value) + ' ' + (rate ? defaultCurrency : 'PIVX');
                        }
                    })]
                };

                const render = data => {
                    const currency = rate ? defaultCurrency : 'PIVX';
                    document.querySelectorAll(`#${id} .currency`).forEach(c => c.innerText = currency);
                    document.querySelectorAll(`#${id} [data-balance]`).forEach(c => {
                        const value = Number.parseFloat(c.dataset.balance);
                        c.innerText = valueTransform(value);
                    });
                    if (!data || !data.series) return;

                    const series = data.series.map(Number);
                    const min = Math.min(...series);
                    const max = Math.max(...series);
                    const low = Math.max(min - ((max - min) / 5), 0);
                    const pointCount = series.length;
                    const labelEvery = pointCount / labelCount;
                    const renderOpts = Object.assign({}, chartOpts, {
                        low,
                        axisX: {
                            labelInterpolationFnc(date, i) {
                                return i % labelEvery === 0 ? dateFormatter.format(new Date(date)) : null;
                            }
                        }
                    });
                    new Chartist.Line(`#${id} .ct-chart`, { labels: data.labels, series: [series] }, renderOpts);
                };

                const update = async type => {
                    const response = await fetch(baseUrl.replace(/\/week$/gi, `/${type}`));
                    if (response.ok) {
                        data = await response.json();
                        render(data);
                    }
                };

                function init() {
                    reposition();
                    render(data);
                    delegate('change', `#${id} [name="PivxWalletBalancePeriod-${storeId}"]`, async e => {
                        await update(e.target.value);
                    });
                    delegate('change', `#${id} .currency-toggle input`, async e => {
                        if (e.target.value === defaultCurrency) {
                            rate = await DashboardUtils.fetchRate(`PIVX_${defaultCurrency}`);
                            if (rate) render(data);
                        } else {
                            rate = null;
                            render(data);
                        }
                    });
                }

                if (document.readyState === "loading") {
                    window.addEventListener("DOMContentLoaded", init);
                } else {
                    init();
                }
            })();
        </script>
    </div>
}
